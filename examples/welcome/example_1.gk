fun ask_name() {
  putln("👋 Hey there! What's your name?")
  return readln()
}

fun greet(name) {
  greetings := [
    "Nice to meet you",
    "Welcome aboard",
    "Glad you're here",
    "Hey"
  ]

  greeting := greetings.choice()
  putln("🎉 " + greeting + ", " + name)

  if len_of(name) < 3 {
    putln("That's a pretty short name 😄")
  } else if len_of(name) > 10 {
    putln("Wow, that's a long name 😳")
  } else {
    putln("Cool name 👍")
  }
}

name := ask_name()
greet(name)
